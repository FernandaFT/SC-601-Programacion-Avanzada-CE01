@model List<CasoEstudio01.Models.MatriculaConsultaModel>

@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="main-panel">
    <div class="content-wrapper">
        <div class="page-header">
            <a href="@Url.Action("Index", "Home")"
               class="btn btn-gradient-danger btn-rounded btn-fw">
                <i class="mdi mdi-arrow-left"></i>
                Ir al Inicio
            </a>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card bg-gradient-success card-img-holder">
                    <div class="card-body">
                        <img src="~/Template/image/circle.svg" class="card-img-absolute" alt="circle-image" />

                        <h4 class="card-title text-center">
                            Consulta de Matrícula
                        </h4>

                        <table class="table text-center">
                            <thead>
                                <tr>
                                    <th>Fecha</th>
                                    <th>Monto</th>
                                    <th>Descripcion</th>
                                    <th>Identificación</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.Fecha</td>
                                        <td>@item.Monto</td>
                                        <td>@item.DescripcionTipoCurso</td>
                                        <td>@item.Identificacion</td>
                                    </tr>
                                }
                            </tbody>
                        </table>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
