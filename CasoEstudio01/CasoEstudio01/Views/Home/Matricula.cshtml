@model CasoEstudio01.Models.MatriculaModel

@{
    Layout = "~/Views/Shared/_LayoutExterno.cshtml";
}

<div class="row justify-content-center">
    <div class="col-md-6 grid-margin stretch-card">
        <div class="card bg-gradient-info card-img-holder text-white">
            <div class="card-body">

                <img src="~/Template/image/circle.svg"
                     class="card-img-absolute"
                     alt="circle-image" />

                <h4 class="card-title text-center text-white">
                    Matrícula de Estudiantes
                </h4>

                @using (Html.BeginForm("Matricula", "Home",FormMethod.Post,new { @id = "FormMatricula" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="form-group">
                        <label>Identificación</label>
                        @Html.TextBoxFor(m => m.Identificacion,new { @placeholder = "Identificación", @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Identificacion, "",new { @class = "text-light" })
                    </div>

                    <div class="form-group">
                        <label>Monto</label>
                        @Html.TextBoxFor(m => m.Monto,new {@placeholder = "Monto",@class = "form-control",type = "number",step = "0.01"})
                        @Html.ValidationMessageFor(m => m.Monto, "",new { @class = "text-light" })
                    </div>

                    <div class="form-group">
                        <label>Tipo de Curso</label>
                        @Html.DropDownListFor(m => m.TipoCurso,Model.ListaTiposCursos,"Seleccione un tipo de curso",new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.TipoCurso, "",new { @class = "text-light" })
                    </div>

                    <button type="submit"
                            class="btn btn-gradient-danger btn-rounded btn-fw me-2">
                        Procesar
                    </button>
                }

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-danger mt-3">
                        @ViewBag.Mensaje
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<script src="~/Template/js/funciones/matricula.js"></script>